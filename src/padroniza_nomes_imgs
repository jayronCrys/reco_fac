import os
import shutil

def organizar_fotos(pasta_origem, id_usuario=1):
    """
    Lê as fotos de uma pasta de origem e as copia para a pasta 'banco_faces'
    no formato exigido pelo algoritmo de reconhecimento: usuario.{id}.{numero}.jpg que é o padrão que o openCv espera
    """
    pasta_destino = 'banco_faces'
    
    # Criar a pasta de destino se ela não existir
    if not os.path.exists(pasta_destino):
        os.makedirs(pasta_destino)
        print(f"Pasta '{pasta_destino}' criada com sucesso.")

    # Listar todos os arquivos da pasta de origem
    try:
        arquivos = os.listdir(pasta_origem)
    except FileNotFoundError:
        print(f"Erro: A pasta de origem '{pasta_origem}' não foi encontrada.")
        return


    # Extensões de imagem permitidas
    extensoes_validas = ('.jpg', '.jpeg', '.png', '.webp')
    
    contador_amostras = 1

    print(f"Iniciando a renomeação das fotos da pasta '{pasta_origem}'...")


    for arquivo in arquivos:
        # Verificar se o arquivo é uma imagem válida pela extensão
        if arquivo.lower().endswith(extensoes_validas):
            caminho_antigo = os.path.join(pasta_origem, arquivo)
            
            # Define o nome no padrão usuario.ID.CONTADOR.jpg

            novo_nome = f"usuario.{id_usuario}.{contador_amostras}.jpg"
            caminho_novo = os.path.join(pasta_destino, novo_nome)
            
            # Copia o arquivo renomeando (shutil.copy mantém o original intacto)
            shutil.copy(caminho_antigo, caminho_novo)
            
            print(f" Copiado: {arquivo}  ->  {novo_nome}")
            contador_amostras += 1

    if contador_amostras > 1:
        print(f"\nSucesso! {contador_amostras - 1} fotos foram organizadas na pasta '{pasta_destino}'.")
    else:
        print("\nNenhuma imagem válida encontrada na pasta de origem.")


if __name__ == "__main__":
    #COLOQUE AQUI O NOME DA PASTA ONDE ESTÃO AS FOTOS ATUAIS
    # Pode ser o nome da pasta ou caminho completo se estiver fora do projeto

    PASTA = "minhas_fotos_originais" 
    
    # 1 para você, 2 de outra pessoa..., para cada pasta, cada um com uma pessoa diferente, o id deve ser mudado se não gera conflito
    ID = 1

    organizar_fotos(PASTA, ID)
